{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "description": "Batch IDs DTO",
  "BatchIdsDto": {
    "type": "object",
    "properties": {
      "identifierType": {
        "description": "Type of identifier",
        "type": "string",
        "enum": [
          "id",
          "hrid",
          "accessionNumber",
          "formerIds",
          "barcode",
          "holdingsRecordId",
          "instanceHrid",
          "itemBarcode"
        ]
      },
      "identifierValues": {
        "description": "Values of identifier",
        "type": "array",
        "items": {
          "description": "Value of identifier",
          "type": "string"
        }
      }
    }
  }
}
