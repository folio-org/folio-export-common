{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "description": "SrsRecord Collection",
  "SrsRecordCollection": {
    "type": "object",
    "properties": {
      "sourceRecords": {
        "description": "List of srs records",
        "type": "array",
        "items": {
          "$ref": "srsRecord.json#/SrsRecord"
        }
      },
      "totalRecords": {
        "type": "integer"
      }
    },
    "additionalProperties": false,
    "required": [
      "sourceRecords",
      "totalRecords"
    ]
  }
}
